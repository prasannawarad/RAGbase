# Server-only (used by /api/embed and /api/chat). Never expose with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Supabase — server / API routes only (never NEXT_PUBLIC_; never import in "use client")
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — browser only (safe to expose; use with RLS). Optional until client uses Supabase directly.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
